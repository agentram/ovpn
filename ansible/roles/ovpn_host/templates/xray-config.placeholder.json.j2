{
  "log": {
    "loglevel": "warning"
  },
  "stats": {},
  "policy": {
    "levels": {
      "0": {
        "statsUserUplink": true,
        "statsUserDownlink": true
      }
    },
    "system": {
      "statsOutboundUplink": true,
      "statsOutboundDownlink": true
    }
  },
  "api": {
    "tag": "api",
    "services": ["StatsService", "HandlerService"]
  },
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "inboundTag": ["api"],
        "outboundTag": "api"
      }
    ]
  },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": {{ ovpn_xray_api_port }},
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1"
      },
      "tag": "api"
    },
    {
      "tag": "vless-reality",
      "listen": "0.0.0.0",
      "port": {{ ovpn_xray_inbound_port }},
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "{{ ovpn_xray_bootstrap_uuid }}",
            "email": "{{ ovpn_xray_bootstrap_email }}",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "target": "{{ ovpn_reality_target }}",
          "xver": 0,
          "serverNames": ["{{ ovpn_reality_server_name }}"],
          "privateKey": "{{ ovpn_reality_private_key }}",
          "shortIds": ["{{ ovpn_reality_short_id }}"]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"],
        "routeOnly": true
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    },
    {
      "protocol": "freedom",
      "tag": "api"
    }
  ]
}
