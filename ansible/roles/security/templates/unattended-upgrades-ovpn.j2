// Managed by Ansible (ovpn security role)
//
// Conservative default:
// - install Ubuntu security and ESM security updates automatically
// - leave normal Ubuntu updates, Docker updates, and reboots for manual maintenance
// - apply package blacklists only when explicitly declared in inventory

#clear Unattended-Upgrade::Allowed-Origins;
Unattended-Upgrade::Allowed-Origins {
        "${distro_id}:${distro_codename}";
        "${distro_id}:${distro_codename}-security";
        "${distro_id}ESMApps:${distro_codename}-apps-security";
        "${distro_id}ESM:${distro_codename}-infra-security";
{% if ovpn_unattended_enable_ubuntu_updates | default(false) | bool %}
        "${distro_id}:${distro_codename}-updates";
{% endif %}
};

#clear Unattended-Upgrade::Package-Blacklist;
Unattended-Upgrade::Package-Blacklist {
{% for package in ovpn_unattended_package_blacklist | default([]) %}
        "{{ package }}";
{% endfor %}
};

Unattended-Upgrade::Automatic-Reboot "{{ (ovpn_unattended_auto_reboot | default(false) | bool) | ternary('true', 'false') }}";
Unattended-Upgrade::Automatic-Reboot-WithUsers "{{ (ovpn_unattended_auto_reboot_with_users | default(false) | bool) | ternary('true', 'false') }}";
Unattended-Upgrade::Automatic-Reboot-Time "{{ ovpn_unattended_auto_reboot_time | default('03:30') }}";
