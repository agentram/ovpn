XRAY_IMAGE=ghcr.io/xtls/xray-core:26.3.27
OVPN_AGENT_IMAGE=alpine:3.23.4
OVPN_TELEGRAM_BOT_IMAGE=alpine:3.23.4
OVPN_AGENT_LOG_LEVEL=info
OVPN_AGENT_HOST_PORT=19000
OVPN_TELEGRAM_BOT_HOST_PORT=19001
OVPN_AGENT_CERT_FILE=/tmp/ovpn-agent-cert.pem
OVPN_CERT_FULLCHAIN_PATH=/dev/null
OVPN_SECURITY_PROFILE=minimal
OVPN_THREAT_DNS_SERVERS=9.9.9.9,149.112.112.112
PROMETHEUS_IMAGE=prom/prometheus:v3.11.2
ALERTMANAGER_IMAGE=prom/alertmanager:v0.32.0
GRAFANA_IMAGE=grafana/grafana:12.4.3
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.11.1
CADVISOR_IMAGE=ghcr.io/google/cadvisor:0.56.2
GRAFANA_ADMIN_USER=ovpn
GRAFANA_ADMIN_PASSWORD=change-me-now
GRAFANA_PORT=3000
OVPN_TELEGRAM_ALLOWED_CHAT_IDS=
OVPN_TELEGRAM_ALLOWED_USER_IDS=
OVPN_TELEGRAM_NOTIFY_CHAT_IDS=
OVPN_TELEGRAM_OWNER_USER_ID=
OVPN_TELEGRAM_CLIENTS_PDF_PATH=/opt/ovpn-telegram-bot/assets/clients.pdf
OVPN_TELEGRAM_LINK_ADDRESS=
OVPN_TELEGRAM_LINK_SERVER_NAME=
OVPN_TELEGRAM_LINK_PUBLIC_KEY=
OVPN_TELEGRAM_LINK_SHORT_ID=
