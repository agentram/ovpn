{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Down",
                  "color": "red"
                },
                "1": {
                  "text": "Up",
                  "color": "green"
                },
                "-1": {
                  "text": "Not proxy",
                  "color": "blue"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "max(up{job=\"haproxy\"}) or vector(-1)",
          "refId": "A"
        }
      ],
      "title": "HAProxy Scrape Target",
      "type": "stat",
      "description": "Proxy-only panel. Not proxy means this dashboard is being viewed on a regular VPN host."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(haproxy_backend_status{proxy=\"foreign_backends\",state=\"UP\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Healthy Foreign Backends",
      "type": "stat",
      "description": "Proxy-only: number of foreign backend servers currently marked UP by HAProxy."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(haproxy_backend_status{proxy=\"foreign_backends\",state=\"DOWN\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Down Foreign Backends",
      "type": "stat",
      "description": "Proxy-only: number of foreign backend servers currently marked DOWN by HAProxy."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "increase(haproxy_backend_check_up_down_total{proxy=\"foreign_backends\"}[15m]) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Backend State Changes (15m)",
      "type": "stat",
      "description": "Proxy-only: backend UP/DOWN state changes in the last 15 minutes. Non-zero can indicate flapping."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by(state) (haproxy_backend_status{proxy=\"foreign_backends\"}) or vector(0)",
          "legendFormat": "backend state",
          "refId": "A"
        }
      ],
      "title": "Foreign Backend Pool Status",
      "type": "timeseries",
      "description": "Proxy-only: current HAProxy backend pool state split by UP/DOWN state."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by(server) (increase(haproxy_server_check_up_down_total{proxy=\"foreign_backends\"}[24h])) or vector(0)",
          "legendFormat": "{{server}}",
          "refId": "A"
        }
      ],
      "title": "Per-Backend Failover Events",
      "type": "timeseries",
      "description": "Proxy-only: backend health transition counts per backend over the selected window."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{job=\"cadvisor\",container_label_com_docker_compose_service=\"haproxy\"}[5m])) * 100 or vector(0)",
          "legendFormat": "haproxy",
          "refId": "A"
        }
      ],
      "title": "HAProxy CPU Usage",
      "type": "timeseries",
      "description": "Proxy-only: HAProxy container CPU usage as a percent of one CPU core."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 8,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{job=\"cadvisor\",container_label_com_docker_compose_service=\"haproxy\"}) or vector(0)",
          "legendFormat": "haproxy",
          "refId": "A"
        }
      ],
      "title": "HAProxy Memory Working Set",
      "type": "timeseries",
      "description": "Proxy-only: HAProxy container working-set memory."
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "ovpn",
    "proxy",
    "haproxy"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-12h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "ovpn Proxy HA Overview",
  "uid": "ovpn-proxy",
  "version": 1,
  "weekStart": "",
  "description": "Proxy-only dashboard. On regular VPN hosts the HAProxy scrape target is shown as Not proxy and backend panels stay at zero."
}
