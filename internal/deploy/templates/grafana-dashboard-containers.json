    {
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS"
      },
      "description": "1 means cAdvisor sees the xray service container.",
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "max((time() - container_last_seen{job=\"cadvisor\",container_label_com_docker_compose_service=\"xray\"}) < bool 120) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "xray Present",
      "type": "stat"
    },
